FROM ubuntu:latest

RUN apt update && apt upgrade -y
RUN apt install -y jq

WORKDIR /opt/server-mgr

COPY ./common/utils.sh /opt/server-mgr/common/utils.sh
COPY ./project_info.json /opt/server-mgr
COPY ./load_config.sh /opt/server-mgr
COPY ./default_config.sh /opt/server-mgr
COPY ./javman.sh /opt/server-mgr
COPY ./docker/package_installer.sh /opt/server-mgr/package_installer.sh

CMD ["bash", "-c", "./package_installer.sh \"$PACKAGES\" && ./javman.sh -I install"]

